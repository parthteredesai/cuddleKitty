<h1>Find Your Perfect Cat</h1>

<form method="POST" action="/match/find-match">

<label>Living Type</label>

<select name="living">

<option>Apartment</option>

<option>House</option>

</select>

<br><br>

<label>Children</label>

<select name="children">

<option>No</option>

<option>Yes</option>

</select>

<br><br>

<label>Other Pets</label>

<select name="pets">

<option>None</option>

<option>Dog</option>

<option>Cat</option>

</select>

<br><br>

<label>Experience</label>

<select name="experience">

<option>Beginner</option>

<option>Experienced</option>

</select>

<br><br>

<label>Preferred Activity</label>

<select name="activity">

<option>Calm</option>

<option>Balanced</option>

<option>Playful</option>

</select>

<br><br>

<button>

Find My Match

</button>

</form>