<%- layout('layouts/boilerplate') %>

<div class="container my-5">
    <div class="row mb-4">
        <div class="col text-center">
            <h1 class="display-4 fw-bold text-purple">My Cuddle Kitty Listings</h1>
            <p class="text-muted">Manage the kitties you have posted for cuddles</p>
            <hr class="w-25 mx-auto">
        </div>
    </div>

    <% if (kitties && kitties.length > 0) { %>
        <div class="row g-4">
            <% for (let kitty of kitties) { %>
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                        
                        <% if (kitty.image) { %>
                            <img src="<%= kitty.image %>" class="card-img-top object-fit-cover" style="height: 220px;" alt="<%= kitty.name %>">
                        <% } else { %>
                            <div class="bg-light d-flex align-items-center justify-content-center" style="height: 220px;">
                                <span class="text-muted fs-2"></span>
                            </div>
                        <% } %>

                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="card-title fw-bold mb-0 text-dark"><%= kitty.name %></h5>
                                <span class="badge bg-purple-light text-purple rounded-pill px-3 py-2"><%= kitty.age %> Yrs</span>
                            </div>
                            
                            <p class="card-text text-muted flex-grow-1">
                                <%= kitty.description.length > 100 ? kitty.description.substring(0, 100) + '...' : kitty.description %>
                            </p>

                            <div class="d-flex gap-2 mt-3">
                                <a href="/kitty/<%= kitty._id %>" class="btn btn-outline-primary btn-sm rounded-pill flex-grow-1 viewKittyBtn">View Kitty</a>
                                <a href="/kitty/edit/<%= kitty._id %>" class="btn btn-warning btn-sm rounded-pill text-white px-5 editBtn"> Edit</a>
                            </div>
                            <div class="deleteBtn w-100">
                                <form method="POST" action="/kitty/<%= kitty._id %>/delete?_method=DELETE" class="w-100">
                                    <button class="submit w-100">Delete Kitty</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    <% } else { %>
        <div class="row my-5">
            <div class="col-md-6 mx-auto text-center border p-5 rounded-4 bg-white shadow-sm">
                <span class="fs-1">🐾</span>
                <h3 class="fw-bold mt-3">No Listings Found</h3>
                <p class="text-muted">You haven't added any cuddly kitties to our system yet.</p>
                <a href="/kitty/new" class="btn btn-primary rounded-pill px-4 mt-2">+ Post a Kitty</a>
            </div>
        </div>
    <% } %>
</div>