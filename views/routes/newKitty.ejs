<% layout("/layouts/boilerplate") %>


<div class="form-container">
    <div class="text-center mb-4">
        <i class="fa-solid fa-cat text-primary fs-1 mb-2"></i>
        <h2 class="fw-bold text-dark">List a New Kitty</h2>
        <p class="text-muted">Fill out the details below to find this kitty a perfect home.</p>
    </div>

    <form class="row g-3 needs-validation" method="POST" action="/kitty" novalidate>
        
        <div class="col-md-12">
            <label for="kittyName" class="form-label">Kitty Name :</label>
            <input type="text" class="form-control" id="kittyName" name="name" placeholder="e.g., Whiskers, Luna..." required>
            <div class="valid-feedback">Looks good!</div>
            <div class="invalid-feedback">Please provide a name for the kitty.</div>
        </div>

        <div class="col-md-7">
            <label for="kittyBreed" class="form-label">Breed :</label>
            <input type="text" class="form-control" id="kittyBreed" name="breed" placeholder="e.g., Persian, Siamese, Stray..." required>
            <div class="invalid-feedback">Looks good!</div>
            <div class="invalid-feedback">Please specify the breed (or write Domestic Shorthair/Mix).</div>
        </div>

        <div class="col-md-5">
            <label for="kittyAge" class="form-label">Age (in years) :</label>
            <input type="number" class="form-control" id="kittyAge" name="age" min="0" max="30" step="any" placeholder="e.g., 2" required>
            <div class="valid-feedback">Valid age!</div>
            <div class="invalid-feedback">Please provide a valid age.</div>
        </div>

        <div class="col-md-12">
            <label for="kittyImage" class="form-label">Image URL :</label>
            <input type="url" class="form-control" id="kittyImage" name="image" placeholder="https://example.com/kitty-photo.jpg">
            <div class="form-text text-muted">Leave empty to use our default placeholder image.</div>
            <div class="invalid-feedback">Please provide a valid image URL starting with http:// or https://</div>
        </div>

        <div class="col-md-12">
            <label for="kittyDescription" class="form-label">Description / Bio :</label>
            <textarea class="form-control" id="kittyDescription" name="description" placeholder="Describe the kitty's personality, health, likes, and why they need a home..." required></textarea>
            <div class="invalid-feedback">Please write a small description for the kitty.</div>
        </div>

        <div class="text-center mb-4">
          <p class="text-muted">We know you still love your kitty. <br>Your kitty will forever remember you.<i class="fa-solid fa-heart" style="color: #ff0059;"></i></p>
        </div>

        <div class="col-12 d-flex gap-2 mt-4">
            <button class="btn btn-primary flex-grow-1" type="submit">Publish Listing</button>
            <a href="/kitty" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
    
</div>