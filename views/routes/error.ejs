<% layout("/layouts/boilerplate") %>
// error.ejs page that dis[lays error message]
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5 text-center">
                    <div class="text-danger mb-4">
                        <i class="fa-solid fa-circle-exclamation display-1"></i>
                    </div>
                    
                    <h2 class="fw-bold text-dark mb-3">Something Went Wrong!</h2>
                    
                    <div class="alert alert-danger border-0 text-start py-3 mb-4" role="alert">
                        <h6 class="alert-heading fw-bold mb-1">Error Message:</h6>
                        <p class="mb-0"><%= message %></p>
                    </div>

                    <a href="/kitty" class="btn btn-primary px-4 py-2 fw-semibold">
                        <i class="fa-solid fa-arrow-left me-2"></i>Return to Homepage
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>